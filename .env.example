# Подключение к PostgreSQL (например, Neon)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
# Установите true для облачных БД с обязательным SSL (Neon определяется автоматически)
DB_SSL=true

# Секрет для подписи JWT
JWT_SECRET=

# PORT задаётся хостингом автоматически (Render). Локально по умолчанию 5000.
